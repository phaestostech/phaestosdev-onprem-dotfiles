run:
  timeout: 10m
  modules-download-mode: readonly

linters:
  enable:
    - errcheck
    - gosimple
    - govet
    - ineffassign
    - staticcheck
    - unused
    - gofmt
    - goimports
    - misspell
    - unconvert
    - bodyclose
    - noctx
    - gosec
    - exportloopref

linters-settings:
  errcheck:
    check-type-assertions: true
    check-blank: false
  govet:
    enable-all: true
    disable:
      - fieldalignment
      - shadow
  gofmt:
    simplify: true
  goimports:
    local-prefixes: {{.Module}}
  misspell:
    locale: US
  gosec:
    excludes:
      - G104 # Audit errors not checked
      - G304 # File path provided as taint input

issues:
  exclude-rules:
    - path: _test\.go
      linters:
        - errcheck
        - gosec
    - path: internal/constants/
      linters:
        - gochecknoglobals
    - path: pkg/cli/
      linters:
        - gochecknoglobals

output:
  formats:
    - format: colored-line-number
  print-issued-lines: true
  print-linter-name: true