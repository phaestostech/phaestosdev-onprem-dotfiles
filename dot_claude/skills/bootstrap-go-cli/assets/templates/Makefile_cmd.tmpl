ifneq ($(origin GOPATH), undefined)
	export GOLINT_PATH=$(GOPATH)/bin/golangci-lint
else
	export GOLINT_PATH=$(HOME)/go/bin/golangci-lint
endif

TEST_IGNORE ?= '/constants|/types|/testutils|/cli|/version|/build'

BUILD_DATE=`date -u +"%Y-%m-%dT%H:%M:%SZ"`
GIT_SHA=`git rev-parse HEAD 2>/dev/null || echo "develop"`
VERSION=`git branch --show-current 2>/dev/null || echo "develop"`
LDFLAGS = -s -w -X main.Version=${VERSION} -X main.Date=${BUILD_DATE} -X main.Commit=${GIT_SHA}
TAGS = nomsgpack

all: clean lint build

.PHONY: clean build install compile run
clean:
	rm -f bin/*

compile:
	GOOS=linux GOARCH=amd64 CGO_ENABLED=0 go build -ldflags="${LDFLAGS}" -tags="${TAGS}" -o ./bin/{{.AppName}}-linux-amd64 ./cmd/{{.AppName}}
	GOOS=linux GOARCH=arm64 CGO_ENABLED=0 go build -ldflags="${LDFLAGS}" -tags="${TAGS}" -o ./bin/{{.AppName}}-linux-arm64 ./cmd/{{.AppName}}
	GOOS=darwin GOARCH=amd64 CGO_ENABLED=0 go build -ldflags="${LDFLAGS}" -tags="${TAGS}" -o ./bin/{{.AppName}}-darwin-amd64 ./cmd/{{.AppName}}
	GOOS=darwin GOARCH=arm64 CGO_ENABLED=0 go build -ldflags="${LDFLAGS}" -tags="${TAGS}" -o ./bin/{{.AppName}}-darwin-arm64 ./cmd/{{.AppName}}

build:
	CGO_ENABLED=0 go build -ldflags="${LDFLAGS}" -tags="${TAGS}" -o ./bin/{{.AppName}} ./cmd/{{.AppName}}

install:
	CGO_ENABLED=0 go install -ldflags="${LDFLAGS}" -tags="${TAGS}" ./cmd/{{.AppName}}

run:
	go run -ldflags="${LDFLAGS}" -tags="${TAGS}" ./cmd/{{.AppName}} --help

run-version:
	go run -ldflags="${LDFLAGS}" -tags="${TAGS}" ./cmd/{{.AppName}} version

.PHONY: fmt lint
fmt:
	go fmt ./...

lint:
ifeq (, $(shell golangci-lint --version))
	go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest
endif
	@$(GOLINT_PATH) run --timeout 10m --verbose ./...

.PHONY: test it integration-test coverage check-coverage
test:
	go test -short -count=1 `go list ./... | grep -vE "$(TEST_IGNORE)"` -coverprofile=coverage.out

it:
	go test -count=1 `go list ./... | grep -vE $(TEST_IGNORE)` -coverprofile=coverage.out

integration-test: it
	go tool cover -func=coverage.out

coverage: it
	go tool cover -html=coverage.out

check-coverage:
	go tool cover -html=coverage.out