package logger

import (
	"os"

	"go.uber.org/zap"
	"go.uber.org/zap/zapcore"
)

var log *zap.Logger

// Init initializes the global logger with development (pretty) or production (JSON) config
func Init(jsonOutput bool) *zap.Logger {
	var config zap.Config

	if jsonOutput {
		config = zap.NewProductionConfig()
	} else {
		config = zap.NewDevelopmentConfig()
		config.EncoderConfig.EncodeLevel = zapcore.CapitalColorLevelEncoder
		config.EncoderConfig.EncodeTime = zapcore.ISO8601TimeEncoder
	}

	config.OutputPaths = []string{"stdout"}
	config.ErrorOutputPaths = []string{"stderr"}

	var err error
	log, err = config.Build()
	if err != nil {
		log = zap.NewExample()
	}

	zap.ReplaceGlobals(log)
	return log
}

// InitWithLevel initializes the logger with a specific level
func InitWithLevel(level string, jsonOutput bool) *zap.Logger {
	var zapLevel zapcore.Level
	if err := zapLevel.UnmarshalText([]byte(level)); err != nil {
		zapLevel = zapcore.InfoLevel
	}

	var config zap.Config
	if jsonOutput {
		config = zap.NewProductionConfig()
	} else {
		config = zap.NewDevelopmentConfig()
		config.EncoderConfig.EncodeLevel = zapcore.CapitalColorLevelEncoder
		config.EncoderConfig.EncodeTime = zapcore.ISO8601TimeEncoder
	}

	config.Level = zap.NewAtomicLevelAt(zapLevel)
	config.OutputPaths = []string{"stdout"}
	config.ErrorOutputPaths = []string{"stderr"}

	var err error
	log, err = config.Build()
	if err != nil {
		log = zap.NewExample()
	}

	zap.ReplaceGlobals(log)
	return log
}

// InitCustom initializes the logger with a custom configuration
func InitCustom(cfg *Config) *zap.Logger {
	encoderConfig := zapcore.EncoderConfig{
		TimeKey:        cfg.TimeKey,
		LevelKey:       cfg.LevelKey,
		NameKey:        cfg.NameKey,
		CallerKey:      cfg.CallerKey,
		FunctionKey:    cfg.FunctionKey,
		MessageKey:     cfg.MessageKey,
		StacktraceKey:  cfg.StacktraceKey,
		LineEnding:     zapcore.DefaultLineEnding,
		EncodeLevel:    zapcore.CapitalColorLevelEncoder,
		EncodeTime:     zapcore.ISO8601TimeEncoder,
		EncodeDuration: zapcore.StringDurationEncoder,
		EncodeCaller:   zapcore.ShortCallerEncoder,
	}

	if cfg.JSONOutput {
		encoderConfig.EncodeLevel = zapcore.LowercaseLevelEncoder
	}

	var encoder zapcore.Encoder
	if cfg.JSONOutput {
		encoder = zapcore.NewJSONEncoder(encoderConfig)
	} else {
		encoder = zapcore.NewConsoleEncoder(encoderConfig)
	}

	var zapLevel zapcore.Level
	if err := zapLevel.UnmarshalText([]byte(cfg.Level)); err != nil {
		zapLevel = zapcore.InfoLevel
	}

	core := zapcore.NewCore(
		encoder,
		zapcore.AddSync(os.Stdout),
		zapLevel,
	)

	log = zap.New(core, zap.AddCaller(), zap.AddStacktrace(zapcore.ErrorLevel))
	zap.ReplaceGlobals(log)
	return log
}

// Config holds the logger configuration for custom initialization
type Config struct {
	Level         string // debug, info, warn, error
	JSONOutput    bool   // true for JSON, false for pretty console output
	TimeKey       string // default: "ts"
	LevelKey      string // default: "level"
	NameKey       string // default: "logger"
	CallerKey     string // default: "caller"
	FunctionKey   string // default: "" (omit)
	MessageKey    string // default: "msg"
	StacktraceKey string // default: "stacktrace"
}

// DefaultConfig returns a default configuration for pretty console output
func DefaultConfig() *Config {
	return &Config{
		Level:         "info",
		JSONOutput:    false,
		TimeKey:       "ts",
		LevelKey:      "level",
		NameKey:       "logger",
		CallerKey:     "caller",
		FunctionKey:   "",
		MessageKey:    "msg",
		StacktraceKey: "stacktrace",
	}
}

// Get returns the global logger instance
func Get() *zap.Logger {
	if log == nil {
		return Init(false)
	}
	return log
}

// Sugar returns a sugared logger for printf-style logging
func Sugar() *zap.SugaredLogger {
	return Get().Sugar()
}
