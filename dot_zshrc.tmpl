# OpenSpec shell completions configuration
fpath=("$HOME/.oh-my-zsh/custom/completions" $fpath)
autoload -Uz compinit
compinit

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(
    colored-man-pages
    dotenv
    git
    zsh-autosuggestions
    zsh-interactive-cd
    zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

##############################################################################
############################## BEGIN ZSH CUSTOM ##############################
##############################################################################

# fzf
source <(fzf --zsh)

# zsh-bd
source $HOME/.zsh/plugins/bd/bd.zsh

# Search Backwards Re-binding
bindkey "^R" history-incremental-pattern-search-backward
bindkey '^[[1;5D' backward-word
bindkey '^[[1;5C' forward-word

############################################################################
############################## END ZSH CUSTOM ##############################
############################################################################

#############################################################################
############################## BEGIN FUNCTIONS ##############################
#############################################################################

func checkSSHTunnels() { lsof -i -n | egrep 'ssh' }
func checkSSHDTunnelts() { lsof -i -n | egrep 'sshd' }
func killMySQLTunnel() { sudo kill $(lsof -t -i :3306) }
func whereami() { printf '%s\n' "${PWD##*/}" }
func whichAccount() { aws sts get-caller-identity --profile default | jq '.' }
func destroyTfState() { terraform state rm $(terraform state list | tr '\n' ' ') }
func cleanUpTfState() { terraform state rm $(tfsl | tr '\n' ' ') }
func dockerPsPretty() { docker ps --format 'table {{ `{{.ID}}` }}\t{{ `{{.Names}}` }}\t{{ `{{.Image}}` }}\t{{ `{{.Status}}` }}\t{{ `{{.Command}}` }}\t{{ `{{.RunningFor}}` }}' }
func dockerContainerLsPretty() { docker container ls -a --format 'table {{ `{{.ID}}` }}\t{{ `{{.Names}}` }}\t{{ `{{.Image}}` }}\t{{ `{{.Status}}` }}\t{{ `{{.RunningFor}}` }}' }
func dotEnv() { export $(egrep -v '^#' .env | xargs) }
func dotEnvLocal() { export $(egrep -v '^#' .env.local | xargs) }
func checkovHere() { checkov --config-file ~/Developments/devops-buildkite-quality-gates/config/.checkov.terraform.yml -d ./ }
func findTerragruntCache() { find . -type d -name ".terragrunt-cache" }
func deleteTerragruntCache() { find . -type d -name ".terragrunt-cache" -prune -exec rm -rf {} \; }
func checkDirSize() { du -sh *; }
func argocdPortForward() { kubectl port-forward svc/argocd-server -n argocd 8080:443 }
func shrug() { echo '¯\_(ツ)_/¯' }
func showTerminalColours() { for i in {0..255}; do print -Pn "%K{$i}  %k%F{$i}${(l:3::0:)i}%f " ${${(M)$((i%6)):#3}:+$'\n'}; done }

# Top-N largest directories (summarised) at a given depth
bigdirs() {
  local dir=${1:-.} n=${2:-20} depth=${3:-1}
  du -k -d "${depth}" -- "${dir}" 2>/dev/null \
  | sort -nr \
  | awk -v n="${n}" '
  function human(x,   u,i){split("B KB MB GB TB PB",u," ");for(i=1;x>=1024 &&
  i<length(u);i++)x/=1024;printf "%.1f %s", x, u[i]}
  NR>1 { printf "%8s  %s\n", human($1*1024), $2; if(++c>=n) exit }'
}

# Top-N largest files recursively (uses zsh glob ordering)
bigfiles() {
  emulate -L zsh -o extendedglob
  local dir=${1:-.} n=${2:-20}
  local -a files
  files=(${dir}/**/*(.DOL[1,${n}]))
  (( ${#files} )) && ls -lh -- "${files[@]}"
}

#############################################################################
############################### END FUNCTIONS ###############################
